#!/usr/bin/env bash
# o-browser — entry point.
#
# Container lifecycle commands run as bash inline; browser actions, session
# management and extensions are routed to cli/o-browser.ts via tsx.
set -euo pipefail

# Resolve $0 through any chain of symlinks (portable across Linux + macOS).
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  LINK_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$LINK_DIR/$SCRIPT"
done
REPO_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

HOME_DIR="${O_BROWSER_HOME:-$HOME/.o-browser-full}"
BASE_URL="${O_BROWSER_URL:-http://localhost:8080}"
HEALTH_URL="$BASE_URL/health"

usage() {
  cat <<EOF
Usage: o-browser <command>

Container:
  start         Start the container (docker compose up -d)
  stop          Stop and remove the container
  restart       stop + start
  status        Hit /health, print "ok" or "down"
  logs          Follow container logs (Ctrl-C to exit)
  pull          Pull the latest image
  shell         Drop a bash shell inside the container
  home          Print the install directory

Session / browser actions / extensions:
  session start|stop|current      Browser session lifecycle
  vnc                              Print VNC viewer URL
  nav | back | forward | reload    Navigation
  read | dom | screenshot          Read DOM / save screenshots
  url | title
  click | type | press | wait      Interaction (Playwright via CDP)
  extension install|list|remove|upgrade
  <ext> <args>                     Run an installed extension

Run \`o-browser help-cli\` for the complete TS-side help.

Env:
  O_BROWSER_HOME   install directory (default: ~/.o-browser-full)
  O_BROWSER_URL    base URL for the container (default: http://localhost:8080)
EOF
}

require_home() {
  if [[ ! -f "$HOME_DIR/docker-compose.yml" ]]; then
    echo "o-browser: install dir not found at $HOME_DIR — run install.sh first" >&2
    exit 1
  fi
}

run_ts() {
  cd "$REPO_DIR"
  exec npx --no-install tsx cli/o-browser.ts "$@"
}

cmd="${1:-}"
case "$cmd" in
  # --- Container lifecycle (inline bash) ---
  start)   require_home; cd "$HOME_DIR"; docker compose up -d ;;
  stop)    require_home; cd "$HOME_DIR"; docker compose down ;;
  restart) require_home; cd "$HOME_DIR"; docker compose down; docker compose up -d ;;
  status)
    if curl -fs "$HEALTH_URL" >/dev/null 2>&1; then
      echo "ok ($HEALTH_URL)"
    else
      echo "down ($HEALTH_URL)"
      exit 1
    fi
    ;;
  logs)    require_home; cd "$HOME_DIR"; docker compose logs -f --tail=200 ;;
  pull)    require_home; cd "$HOME_DIR"; docker compose pull ;;
  shell)   docker exec -it browser bash ;;
  home)    echo "$HOME_DIR" ;;
  ""|-h|--help|help) usage ;;
  help-cli) shift; run_ts help ;;
  # --- Everything else: route to TS dispatcher ---
  *) run_ts "$@" ;;
esac
